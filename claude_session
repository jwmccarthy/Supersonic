  class SimpleCollisionWorld {
  private:
      std::vector<RigidBody*> bodies;
      std::vector<ContactManifold> contactManifolds;

  public:
      void addRigidBody(RigidBody* body) {
          bodies.push_back(body);
      }

      void detectCollisions() {
          contactManifolds.clear();

          // Broadphase - simple grid or quadtree
          std::vector<std::pair<RigidBody*, RigidBody*>> pairs = broadphase.findPotentialPairs(bodies);

          // Narrowphase - direct algorithm selection
          for (auto& pair : pairs) {
              RigidBody* bodyA = pair.first;
              RigidBody* bodyB = pair.second;

              ContactManifold manifold;
              manifold.bodyA = bodyA;
              manifold.bodyB = bodyB;

              bool collision = false;

              // Direct algorithm selection based on shape types
              if (bodyA->getShapeType() == ShapeType::BOX && bodyB->getShapeType() == ShapeType::PLANE) {
                  collision = CollisionAlgorithms::boxPlaneCollision(
                      static_cast<BoxShape*>(bodyA->getShape()), bodyA->getTransform(),
                      static_cast<PlaneShape*>(bodyB->getShape()), bodyB->getTransform(),
                      manifold
                  );
              }
              else if (bodyA->getShapeType() == ShapeType::BOX && bodyB->getShapeType() == ShapeType::TRIANGLE_MESH) {
                  // Request triangles that might intersect with the box
                  AABB boxAABB = bodyA->getAABB();
                  auto triangles = static_cast<TriangleMeshShape*>(bodyB->getShape())->getTrianglesInAABB(boxAABB);

                  for (auto& triangle : triangles) {
                      collision |= CollisionAlgorithms::boxTriangleCollision(
                          static_cast<BoxShape*>(bodyA->getShape()), bodyA->getTransform(),
                          triangle, bodyB->getTransform(),
                          manifold
                      );
                  }
              }
              // Other shape type combinations...

              if (collision) {
                  // For curved surfaces, apply normal smoothing
                  if (bodyB->getShapeType() == ShapeType::TRIANGLE_MESH) {
                      smoothInternalEdgeContacts(manifold);
                  }

                  // Add game-specific properties
                  applyCollisionProperties(manifold);

                  contactManifolds.push_back(manifold);
              }
          }
      }

      void resolveCollisions() {
          for (auto& manifold : contactManifolds) {
              // Calculate and apply impulses
              calculateAndApplyImpulses(manifold);
          }
      }

  private:
      void applyCollisionProperties(ContactManifold& manifold) {
          // Apply game-specific collision properties
          // Similar to the RocketSim callback system, but direct

          RigidBody* bodyA = manifold.bodyA;
          RigidBody* bodyB = manifold.bodyB;

          // Apply Rocket League specific friction/restitution values
          float friction = 0.3f;
          float restitution = 0.1f;

          if (bodyA->getUserType() == UserType::CAR && bodyB->getUserType() == UserType::WORLD) {
              Car* car = static_cast<Car*>(bodyA->getUserPointer());

              // Store contact information for car physics
              car->worldContact.hasContact = true;
              car->worldContact.contactNormal = manifold.contacts[0].normal;

              friction = 0.6f;     // Car-world friction
              restitution = 0.1f;  // Car-world restitution
          }

          // Apply to all contact points
          for (auto& contact : manifold.contacts) {
              contact.friction = friction;
              contact.restitution = restitution;
          }
      }

      void smoothInternalEdgeContacts(ContactManifold& manifold) {
          // Simplified edge smoothing for triangle mesh collisions
          if (manifold.bodyB->getShapeType() != ShapeType::TRIANGLE_MESH)
              return;

          TriangleMeshShape* mesh = static_cast<TriangleMeshShape*>(manifold.bodyB->getShape());

          for (auto& contact : manifold.contacts) {
              // Check if this contact is near a triangle edge
              TriangleEdgeInfo edgeInfo = mesh->getEdgeInfo(contact.triangleIndex, contact.edgeIndex);

              if (edgeInfo.isSharedEdge) {
                  // Average the normals of adjacent triangles
                  Vector3 adjacentNormal = mesh->getTriangleNormal(edgeInfo.adjacentTriangleIndex);

                  // Blend normals based on position along edge
                  float blendFactor = calculateEdgeBlendFactor(contact, edgeInfo);
                  contact.normal = lerp(contact.normal, adjacentNormal, blendFactor).normalized();
              }
          }
      }
